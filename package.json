{
  "name": "@decentralchain/node-api-js",
  "version": "1.2.5-beta.18",
  "main": "cjs/index.js",
  "types": "cjs/index.d.ts",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "testCommand": "jest",
    "prepare": "husky",
    "build": "tsc -p ./tsconfig-es.json && tsc -p ./tsconfig-cjs.json && webpack",
    "test": "node-state -e -n -m typescript -o ./test/_state.ts -r",
    "format": "prettier --write \"src/**/*.{ts,tsx,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,json,css}\"",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "bulletproof": "npm run format && npm run lint:fix && npm run typecheck",
    "bulletproof:check": "npm run format:check && npm run lint && npm run typecheck"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/Decentral-America/node-api-js"
  },
  "dependencies": {
    "@decentralchain/bignumber": "npm:@waves/bignumber@^1.2.0",
    "@decentralchain/ts-lib-crypto": "npm:@waves/ts-lib-crypto@^1.4.4",
    "@decentralchain/ts-types": "npm:@waves/ts-types@^1.2.0",
    "@types/node-fetch": "^2.6.13",
    "node-fetch": "^2.7.0",
    "typed-ts-events": "^3.0.1"
  },
  "files": [
    "dist",
    "cjs",
    "es"
  ],
  "jest": {
    "coverageThreshold": {
      "global": {
        "branches": 60,
        "functions": 60,
        "lines": 60,
        "statements": 60
      }
    },
    "collectCoverage": true,
    "coveragePathIgnorePatterns": [
      "/node_modules/",
      "/test/",
      "/src/libs/"
    ],
    "moduleFileExtensions": [
      "ts",
      "tsx",
      "js"
    ],
    "transform": {
      "^.+\\.(ts|tsx)$": "ts-jest"
    },
    "testMatch": [
      "**/test/*spec.+(ts)",
      "**/test/**/*spec.+(ts)"
    ],
    "setupFilesAfterEnv": [
      "<rootDir>/test/extendedMatcher.ts"
    ]
  },
  "devDependencies": {
    "@decentralchain/node-state": "0.1.0",
    "@decentralchain/transactions": "npm:@decentralchain/waves-transactions@4.2.6",
    "@eslint/js": "^10.0.1",
    "@types/babel__traverse": "^7.28.0",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.15.0",
    "eslint": "^10.0.2",
    "eslint-config-prettier": "^10.1.8",
    "globals": "^17.3.0",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "lint-staged": "^16.2.7",
    "prettier": "^3.8.1",
    "ts-jest": "^29.4.6",
    "ts-loader": "^9.5.4",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.56.1",
    "webpack": "^5.105.3",
    "webpack-cli": "^6.0.1"
  },
  "lint-staged": {
    "*.ts": [
      "prettier --write",
      "eslint --fix"
    ],
    "*.json": [
      "prettier --write"
    ]
  }
}
